{
  "name": "@robindarlington/mail-merge",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "mail-merge": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "npm run build",
    "test": "node --import tsx --test \"test/*.test.ts\"",
    "build": "esbuild src/bin.ts --bundle --platform=node --format=esm --tsconfig=tsconfig.json --banner:js=\"import{createRequire as __cr}from'module';const require=__cr(import.meta.url);\" --outfile=dist/bin.js"
  },
  "dependencies": {},
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/node": "^24",
    "esbuild": "^0.25",
    "tsx": "^4.22",
    "zod": "^4.4"
  }
}
