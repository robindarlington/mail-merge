# =============================================================================
# Mail Merge — environment template
# Copy to ".env" and fill in real values. NEVER commit the real .env.
# (.env is gitignored; this file holds placeholders only.)
# =============================================================================

# --- Database (D-09: native dev uses a local SQLite file) -------------------
# Path to the SQLite database file. In production this lives on the shared
# /data Docker volume (e.g. /data/app.db); in dev it sits under ./data.
DATABASE_PATH=./data/app.db

# --- Credential encryption (AES-256-GCM) ------------------------------------
# 32-byte master key used to encrypt SMTP credentials at rest.
# Generate with:  openssl rand -base64 32
# The app FAILS LOUDLY at startup if this is absent or not 32 bytes once decoded.
# Never commit a real key; inject it via .env (dev) or a Coolify secret (prod).
CREDENTIAL_ENC_KEY=replace-with-openssl-rand-base64-32

# --- Clerk auth (consumed in Phase 2; listed now for completeness) ----------
# From the Clerk dashboard. The publishable key is client-safe; the secret key
# is server-only and must never reach the browser or git history.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# --- Server runtime ---------------------------------------------------------
# Bind address for the Next.js standalone server (set to 0.0.0.0 in Docker).
HOSTNAME=0.0.0.0
# Port the web server listens on.
PORT=3000

# --- BYO-SMTP (carried from the CLI; used by dev seed / onboarding tests) ----
# These are the sender's own SMTP server details. In the web app each user
# provides their own via the onboarding form; these env vars only seed local
# dev / CLI parity. SMTP_PASS is a secret — never commit a real value.
SMTP_HOST=smtp.example.com
SMTP_PORT=465                  # 465 = implicit SSL, 587 = STARTTLS
SMTP_USER=you@example.com
SMTP_PASS=replace-with-smtp-password
FROM_ADDR=you@example.com      # visible "From" address
FROM_NAME=Your Name            # visible "From" display name
