# =============================================================================
# Mail Merge — environment template
# Copy to ".env" and fill in real values. NEVER commit the real .env.
# (.env is gitignored; this file holds placeholders only.)
#
# This file is the COMPLETE contract for every ${VAR} that docker-compose.yml
# interpolates, grouped by purpose. Two classes of variable behave differently
# in production:
#   * BUILD-TIME  (NEXT_PUBLIC_CLERK_*) — inlined into the JS bundle by
#     `next build`. Changing one requires a REBUILD, not a restart.
#   * RUNTIME     (everything else) — read by the container at start; a change
#     needs only a restart/redeploy.
#
# Coolify note: Coolify stores these as plaintext at
#   /data/coolify/applications/<app-id>/.env
# on the VPS. Its "lock" icon only HIDES values in the UI — it is not
# encryption. Treat VPS filesystem access as equivalent to secret access.
# =============================================================================

# --- Database (D-09: native dev uses a local SQLite file) -------------------
# Path to the SQLite database file. In production this lives on the shared
# /data Docker volume (e.g. /data/app.db); in dev it sits under ./data.
DATABASE_PATH=./data/app.db

# Directory where uploaded CSVs are written. In production Coolify sets this to
# /data/uploads so uploads land on the shared /data volume (durable across
# restarts, same volume as app.db); in dev it falls back to ./data/uploads.
# Mirrors the DATABASE_PATH dev/prod convention. storage_path values are stored
# RELATIVE (<uuid>.csv) so they resolve against this dir on either side.
UPLOADS_PATH=./data/uploads

# --- Credential encryption (AES-256-GCM) — RUNTIME SECRET -------------------
# 32-byte master key used to encrypt SMTP credentials at rest.
# Generate with:  openssl rand -base64 32
# The app FAILS LOUDLY at startup if this is absent or not 32 bytes once decoded.
# Never commit a real key; inject it via .env (dev) or a Coolify secret (prod).
# Coolify: mark "Is Literal?" — the base64 value can contain $ or @, which
# Coolify would otherwise try to expand/interpolate. RUNTIME-ONLY: never a
# build arg or image layer (compose injects it via `environment:`).
CREDENTIAL_ENC_KEY=replace-with-openssl-rand-base64-32

# --- Clerk auth (Phase 2) ---------------------------------------------------
# From the Clerk dashboard (use the DEVELOPMENT instance for local + staging,
# D-13).
#
# NEXT_PUBLIC_CLERK_* are BUILD-TIME vars: `next build` inlines them into the
# client bundle (Pitfall 3), so they must be present when the image is built —
# compose passes them through `web.build.args`. Changing any of them requires a
# REBUILD, not a restart. On Coolify these are plain UI env vars picked up by
# build.args; do NOT rely on the "Build Variable" toggle (a no-op for compose
# apps — RESEARCH Finding 5 / Pitfall 4).
#
# The publishable key is client-safe. CLERK_SECRET_KEY is server-only (RUNTIME
# secret, see below) and must never reach the browser, git history, or a build
# arg.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# CLERK_SECRET_KEY — RUNTIME SECRET (compose injects via `environment:`, never a
# build arg). Coolify: mark "Is Literal?" for safety, same rationale as
# CREDENTIAL_ENC_KEY.
CLERK_SECRET_KEY=sk_test_replace_me
# Dedicated sign-in / sign-up pages (D-10). Setting SIGN_IN_URL is also the
# workaround for clerk/javascript#8302 so auth.protect() redirects to /sign-in
# instead of looping on the current URL (Pitfall 2). BUILD-TIME (NEXT_PUBLIC_*).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Where users land after a successful sign-in / sign-up. BUILD-TIME.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Server runtime ---------------------------------------------------------
# Bind address for the Next.js standalone server (set to 0.0.0.0 in Docker).
# In compose this is set on the web service (HOSTNAME: "0.0.0.0").
HOSTNAME=0.0.0.0
# Port the web server listens on.
PORT=3000

# --- Background worker knobs (RUNTIME, worker service) ----------------------
# Consumed by the worker process (worker/index.ts + lib/worker). All are safe to
# omit — the compose file supplies these same defaults via ${VAR:-default}, so
# these entries just document the contract and let you override per-deploy.
#
# Existing send-loop knobs:
# Pause between individual sends (ms) — the per-recipient throttle.
SEND_DELAY_MS=1000
# How often the worker polls for queued work when idle (ms).
WORKER_POLL_MS=2000
# Lease/visibility window for a claimed job (seconds); a hung send is reclaimed
# after this elapses.
WORKER_LEASE_SEC=300
#
# New maintenance tunables (Phase 8, consumed by lib/worker via plan 08-03):
# How often the worker forces a SQLite WAL checkpoint (ms) to keep the -wal
# sidecar bounded between campaigns. Default 3600000 = 1 hour.
WAL_CHECKPOINT_MS=3600000
# How often the worker sweeps orphaned upload / attachment files off /data (ms).
# Default 3600000 = 1 hour.
ORPHAN_SWEEP_MS=3600000
# Age (in days) after which an orphaned attachment file becomes eligible for the
# sweep above. Default 7 days.
ATTACHMENT_ORPHAN_DAYS=7

# --- BYO-SMTP (carried from the CLI; used by dev seed / onboarding tests) ----
# These are the sender's own SMTP server details. In the web app each user
# provides their own via the onboarding form; these env vars only seed local
# dev / CLI parity. SMTP_PASS is a secret — never commit a real value.
SMTP_HOST=smtp.example.com
SMTP_PORT=465                  # 465 = implicit SSL, 587 = STARTTLS
SMTP_USER=you@example.com
SMTP_PASS=replace-with-smtp-password
FROM_ADDR=you@example.com      # visible "From" address
FROM_NAME=Your Name            # visible "From" display name
